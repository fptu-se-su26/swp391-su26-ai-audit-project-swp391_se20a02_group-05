# ==============================================================================
# CVERIFY AI FastAPI MICROSERVICE — ENVIRONMENT TEMPLATE
# ==============================================================================
# Copy this file to .env and fill in the values before running the service.
#   cp .env.example .env
#
# NEVER commit the real .env file to version control.
# ==============================================================================

# 1. ANTHROPIC CLAUDE SDK KEY
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 2. CORE SECURITY SIGNATURES (HMAC SHA-256)
# Shared secret must exactly match the value configured in CVerify.Core
SHARED_SECRET=your_shared_secret_here
CLIENT_ID=cverify-core

# 3. FASTAPI SERVER HOST & PORT
HOST=0.0.0.0
PORT=8000

# 4. REDIS (Caching & Nonce Verification for Replay Attack Protection)
REDIS_URL=redis://redis:6379/0

# 5. CORE AI MODEL CONFIGURATION
CLAUDE_MODEL=claude-haiku-4-5-20251001

# 6. CERTIFICATE IMAGE OCR — VISION FALLBACK (optional)
# When set to true, the image extractor will call Claude Vision (Haiku) as a
# Tier-2 fallback when pytesseract returns empty text on a certificate image.
# Costs approx. $0.00025 per certificate image. Disabled by default.
ENABLE_VISION_CERTIFICATE_OCR=false

# 7. DEBUG / OBSERVABILITY
AI_DEBUG_MODE=false
