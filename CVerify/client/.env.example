# ==============================================================================
# CVERIFY FRONTEND CONFIGURATION (.env.example)
# ==============================================================================

# 1. BACKEND API URL
# The URL pointing to the ASP.NET Core v10 backend RESTful endpoints.
NEXT_PUBLIC_API_URL=http://localhost:5247/api

# 2. JWT CLIENT SECURITY SECRET
# Secret used for edge-side cryptographic token verification in the Security Proxy.
# MUST match the JWT key or a secondary client validation token.
JWT_SECRET=DbqDgBM1u2H5lNnUFBgYrRaotpSP9Wda8jASgjIbFh6

# 3. GOOGLE OAUTH CLIENT ID
# Required for facilitating Google Single Sign-On (SSO) login flow.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
