# ==============================================================================
# CVERIFY INFRASTRUCTURE CONFIGURATION (.env.example)
# ==============================================================================
# Copy this file to .env and fill in the values before running the service.
#   cp .env.example .env
#
# NEVER commit the real .env file to version control.
# ==============================================================================

# 1. DATABASE (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cverify_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# 2. REDIS (Caching & Distributed State)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# 3. JWT SECURITY
# Key must be at least 32 characters long for HS256
JWT_KEY="YOUR_SUPER_SECRET_KEY_HERE_MIN_32_CHARS"

# 4. ASP.NET CORE ENVIRONMENT
ASPNETCORE_ENVIRONMENT=Development
PORT=5247

# 5. EMAIL INFRASTRUCTURE (SMTP / SendGrid)
EMAIL_SENDER_EMAIL=dev@cverify.ai
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=dev_user
SMTP_PASSWORD=dev_password
SENDGRID_API_KEY=SG.your_sendgrid_key_here

# 6. OAUTH CONFIGURATIONS
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

GITLAB_CLIENT_ID=your_gitlab_client_id_here
GITLAB_CLIENT_SECRET=your_gitlab_client_secret_here

# 7. AI MICROSERVICE CONFIGURATION
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SHARED_SECRET="YOUR_HMAC_SHARED_SECRET_KEY_MIN_32_CHARS"
AI_SERVICE_CLIENT_ID=cverify-core
CLAUDE_MODEL=claude-sonnet-4-6

# 8. PRIVILEGED SYSTEM IDENTITY (SUPER ADMIN)
SUPER_ADMIN_EMAIL=admin@system.com
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_FULL_NAME="System Administrator"
SUPER_ADMIN_PASSWORD=SuperAdminPassword123

# 9. CLOUDFLARE R2 OBJECT STORAGE
ACCESS_KEY_ID=your_r2_access_key_id_here
SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET=cverify-evidence

# 10. SECURITY SETTINGS
DISABLE_RATE_LIMITS=false
# Key must be exactly 32 bytes (256 bits) for AES-256-GCM
TOKEN_ENCRYPTION_KEY="your_32_byte_token_encryption_key_here"

# 11. DATABASE MANAGEMENT
RESET_DATABASE=false

# 12. DATABASE SEED CONFIGURATION
SEED_TEST_ACCOUNTS=true
SEED_BUSINESS_PASSWORD=TestPassword123
SEED_DATA_PATH=resources/seed-business-data.json
PUBLIC_DEMO_DATA_PATH=resources/public-workspace-demo-content.json
ALLOW_DEVELOPMENT_SEEDING=true

# 13. FRONTEND URL (CORS & Auth Redirects)
# Used for CORS origin policy and authentication redirect URLs
FRONTEND_URL=http://localhost:3000
