class User <<Shared/Domain>> {
  +Guid Id = Guid.CreateVersion7()
  +string Email  <<citext>>
  +string? Username  <<citext, 32>>
  +DateTimeOffset? LastUsernameChangeAt
  +string? PasswordHash
  +DateTimeOffset? PasswordChangedAt
  +string FullName  <<255>>
  +string? AvatarUrl
  +AvatarSource AvatarSource = Default
  +UserStatus Status = EMAIL_VERIFY_PENDING
  +DateTimeOffset? EmailVerifiedAt
  +DateTimeOffset? LastLoginAt
  +IPAddress? LastLoginIp  <<inet>>
  +int FailedAttempts
  +DateTimeOffset? LastFailedAt
  +DateTimeOffset? LockUntil
  +bool IsLegalHold = false
  +DateTimeOffset CreatedAt
  +DateTimeOffset UpdatedAt
  +DateTimeOffset? DeletedAt
  +uint Version  <<ConcurrencyCheck, xmin>>
  +int SessionVersion = 1
  --navigations--
  +ICollection<Role> Roles
  +ICollection<RefreshToken> RefreshTokens
  +ICollection<AuthProvider> AuthProviders
