<mxfile host="app.diagrams.net"><diagram name="CVerify network and port topology" id="d"><mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1418" pageHeight="1356" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="root" value="CVerify — network &amp; port topology (internet → nginx → loopback → Docker bridge networks)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontColor=#1A1A1A;fontSize=11;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="40" y="70" width="1338" height="1236" as="geometry"/></mxCell><mxCell id="b1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#999999;fontColor=#1A1A1A;fontSize=11;fontStyle=1;verticalAlign=top;" vertex="1" parent="root"><mxGeometry x="106" y="60" width="1127" height="532" as="geometry"/></mxCell><mxCell id="inb" value="Inbound path" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#8C8C8C;fontColor=#1A1A1A;fontSize=11;fontStyle=1;verticalAlign=top;" vertex="1" parent="b1"><mxGeometry x="24" y="38" width="248" height="470" as="geometry"/></mxCell><mxCell id="inet" value="Internet" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;strokeColor=#232F3E;fillColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.internet;" vertex="1" parent="inb"><mxGeometry x="100" y="60" width="48" height="48" as="geometry"/></mxCell><mxCell id="dns2" value="P.A Vietnam DNS (DNSSEC)
cverify.com.vn → VM IP
api.cverify.com.vn → VM IP
NO CDN / NO proxy in front" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#eef3fb,#1f2a38);strokeColor=#5A6B7B;fontColor=#1A1A1A;fontSize=11;fontStyle=0;verticalAlign=middle;" vertex="1" parent="inb"><mxGeometry x="24" y="156" width="200" height="98" as="geometry"/></mxCell><mxCell id="eip2" value="GCP static external IP" style="sketch=0;html=1;outlineConnect=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontColor=#232F3E;aspect=fixed;shape=image;image=data:image/png,;" vertex="1" parent="inb"><mxGeometry x="100" y="268" width="48" height="48" as="geometry"/></mxCell><mxCell id="fw2" value="GCP firewall
allow tcp/80,443 ← 0.0.0.0/0
allow tcp/22 ← restricted IP
EVERYTHING ELSE DENIED" style="sketch=0;html=1;outlineConnect=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontColor=#232F3E;aspect=fixed;shape=image;image=data:image/png,;" vertex="1" parent="inb"><mxGeometry x="100" y="364" width="48" height="48" as="geometry"/></mxCell><mxCell id="edge" value="Host nginx (installed on the VM, not a container) — TLS termination" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B85450;fontColor=#1A1A1A;fontSize=11;fontStyle=1;verticalAlign=top;" vertex="1" parent="b1"><mxGeometry x="312" y="38" width="491" height="470" as="geometry"/></mxCell><mxCell id="nginx" value="nginx :80 → 301 https
nginx :443 TLS1.2/1.3 (Let's Encrypt)" style="sketch=0;html=1;outlineConnect=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontColor=#232F3E;aspect=fixed;shape=image;image=data:image/png,;" vertex="1" parent="edge"><mxGeometry x="222" y="60" width="48" height="48" as="geometry"/></mxCell><mxCell id="vhosts" value="server cverify.com.vn      → upstream 127.0.0.1:3000
server api.cverify.com.vn  → upstream 127.0.0.1:5247
  /hubs/    WebSocket upgrade, read timeout 3600s
  ~ /api/(...)stream   SSE: gzip off, proxy_buffering off, 300s
  limit_req cverify_general 10r/s · cverify_auth 5r/m
  HSTS · nosniff · X-Frame-Options DENY · Referrer-Policy
  Permissions-Policy   —  NO Content-Security-Policy" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#eef3fb,#1f2a38);strokeColor=#5A6B7B;fontColor=#1A1A1A;fontSize=11;fontStyle=0;verticalAlign=middle;" vertex="1" parent="edge"><mxGeometry x="116" y="154" width="260" height="152" as="geometry"/></mxCell><mxCell id="note2" value="Notes verified from source:
• cverify-core and cverify-ai are multi-homed (3 and 2 networks).
• Service-to-service DNS is Docker's embedded resolver:
   cverify-core:5000, cverify-ai:8000, postgres:5432, redis:6379.
• The base docker-compose.yml publishes the client on 0.0.0.0:3000;
   only the prod overlay's `ports: !override` rebinds it to 127.0.0.1.
• No host port maps to MinIO — the S3 client reaches it over
   cverify-infra-net using R2_*-named env vars." style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#f8cecc,#5a2b28);strokeColor=#B85450;fontColor=#1A1A1A;fontSize=11;fontStyle=0;verticalAlign=middle;" vertex="1" parent="b1"><mxGeometry x="843" y="38" width="260" height="170" as="geometry"/></mxCell><mxCell id="lb" value="Host loopback-published container ports (127.0.0.1 only — never 0.0.0.0)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontColor=#1A1A1A;fontSize=11;fontStyle=1;verticalAlign=top;" vertex="1" parent="root"><mxGeometry x="170" y="622" width="998" height="182" as="geometry"/></mxCell><mxCell id="p_client" value="127.0.0.1:3000
→ cverify-client:3000
(prod overlay uses
ports: !override)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#eef3fb,#1f2a38);strokeColor=#5A6B7B;fontColor=#1A1A1A;fontSize=11;fontStyle=0;verticalAlign=middle;" vertex="1" parent="lb"><mxGeometry x="24" y="60" width="167" height="98" as="geometry"/></mxCell><mxCell id="p_core" value="127.0.0.1:5247
