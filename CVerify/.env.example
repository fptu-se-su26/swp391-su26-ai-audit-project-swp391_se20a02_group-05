# ==============================================================================
# CVERIFY UNIFIED ENVIRONMENT CONFIGURATION (.env.example)
# ==============================================================================
# Copy this file to .env and configure the credentials.
# Run the setup scripts (setup.sh / setup.ps1) to auto-populate secure keys.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE LAYER (PostgreSQL + pgvector)
# ------------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cverify_db_dev
DB_USER=postgres
DB_PASSWORD=GENERATE_SECURE_PASSWORD

# ------------------------------------------------------------------------------
# 2. CACHING & STATE LAYER (Redis)
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=GENERATE_SECURE_PASSWORD

# ------------------------------------------------------------------------------
# 3. SECURITY & CRYPTOGRAPHY
# ------------------------------------------------------------------------------
# JWT Signing Key - Must be at least 32 characters long
JWT_KEY=GENERATE_JWT_SECRET_KEY
# AES-256-GCM Token Encryption Key - Must be exactly 32 bytes (64 hex characters or 32 chars)
TOKEN_ENCRYPTION_KEY=GENERATE_TOKEN_ENCRYPTION_KEY

# ------------------------------------------------------------------------------
# 4. ASP.NET BACKEND SERVICE CONFIGURATION (CVerify.Core)
# ------------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
# Core Service Web API Port (inside container/host)
CORE_PORT=5247

# 5. PRIVILEGED SYSTEM IDENTITY (SUPER ADMIN)
SUPER_ADMIN_EMAIL=admin@system.com
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_FULL_NAME="System Administrator"
SUPER_ADMIN_PASSWORD=SuperAdminPassword123

# 6. DATABASE SEED CONFIGURATION
RESET_DATABASE=false
SEED_TEST_ACCOUNTS=true
SEED_BUSINESS_PASSWORD=TestPassword123
SEED_DATA_PATH=resources/seed-business-data.json
PUBLIC_DEMO_DATA_PATH=resources/public-workspace-demo-content.json
ALLOW_DEVELOPMENT_SEEDING=true

# ------------------------------------------------------------------------------
# 5. EMAIL INFRASTRUCTURE (SMTP / SendGrid)
# ------------------------------------------------------------------------------
EMAIL_SENDER_EMAIL=dev@cverify.ai
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=dev_user
SMTP_PASSWORD=dev_password
SENDGRID_API_KEY=SG.your_sendgrid_key_here

# ------------------------------------------------------------------------------
# 6. OAUTH CONFIGURATIONS
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

GITLAB_CLIENT_ID=your_gitlab_client_id_here
GITLAB_CLIENT_SECRET=your_gitlab_client_secret_here

# ------------------------------------------------------------------------------
# 7. AI FastAPI MICROSERVICE CONFIGURATION (CVerify.AI)
# ------------------------------------------------------------------------------
# Anthropic API Key (from: https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Shared secret HMAC key for CVerify.Core and CVerify.AI communication
AI_SERVICE_SHARED_SECRET=GENERATE_AI_SHARED_SECRET
AI_SERVICE_CLIENT_ID=cverify-core

# Host & Port for python microservice
AI_HOST=0.0.0.0
AI_PORT=8000

# Clone detection configuration
CLONE_DETECTION_ENABLED=true
ENABLE_VISION_CERTIFICATE_OCR=false

# Debug & logging level
AI_DEBUG_MODE=false
AI_DEBUG_TOKENS=false

# ------------------------------------------------------------------------------
# 8. OBJECT STORAGE (S3-compatible — Cloudflare R2 or self-hosted MinIO)
# ------------------------------------------------------------------------------
# Program.cs targets a generic S3-compatible endpoint with ForcePathStyle=true,
# so either Cloudflare R2 or a self-hosted MinIO (see deployment/docker-compose.prod.yml's
# `minio` service) works without any application code changes — only these
# values need to point at whichever backend is in use.
ACCESS_KEY_ID=your_r2_access_key_id_here
SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET=cverify-evidence

# Only used when deployment/docker-compose.prod.yml's `minio` service is
# enabled as the R2_ENDPOINT target (e.g. R2_ENDPOINT=http://minio:9000)
# instead of real Cloudflare R2 — sets the MinIO root credentials, which
# should then match ACCESS_KEY_ID/SECRET_ACCESS_KEY above.
MINIO_ROOT_USER=your_minio_root_user_here
MINIO_ROOT_PASSWORD=your_minio_root_password_here

# ------------------------------------------------------------------------------
# 9. CLIENT PORTAL CONFIGURATION (client / Next.js)
# ------------------------------------------------------------------------------
CLIENT_PORT=3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# ------------------------------------------------------------------------------
# 10. PRODUCTION-ONLY — read by deployment/docker-compose.prod.yml
# DOMAIN is the frontend's public host. API_DOMAIN is the API's own subdomain
# (deployment/nginx/cverify.conf routes api.<DOMAIN> straight to cverify-core,
# separately from the frontend). API_DOMAIN feeds NEXT_PUBLIC_API_URL
# (build-time, inlined into the frontend bundle — the client image MUST be
# rebuilt after changing this). BACKEND_URL is used to build OAuth callback
# URLs (falls back to the incoming request's Host header if left unset).
#
# COOKIE_DOMAIN must be set to a shared parent domain (e.g. ".cverify.com.vn")
# whenever the frontend and API are on different subdomains — otherwise the
# access_token/refresh_token/CSRF-TOKEN cookies set by the API are invisible
# to the frontend (breaks SSR auth checks and all CSRF-protected requests).
# Leave COOKIE_DOMAIN unset for single-host/localhost setups.
#
# Auth__TrustedDomains must include DOMAIN or email-verification and
# password-reset links (built from FRONTEND_URL) are rejected as untrusted.
# ------------------------------------------------------------------------------
DOMAIN=localhost
API_DOMAIN=localhost
BACKEND_URL=http://localhost:5247
COOKIE_DOMAIN=
Auth__TrustedDomains=localhost;127.0.0.1
