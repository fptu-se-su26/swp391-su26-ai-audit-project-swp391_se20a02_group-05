# ==============================================================================
# CVERIFY — ROOT ENVIRONMENT TEMPLATE (used by docker-compose.yml)
# ==============================================================================
# Every service in docker-compose.yml points `env_file: - .env` at THIS file
# (not at CVerify.Core/.env, CVerify.AI/.env, or client/.env — those exist
# separately for running each service outside Docker during local dev).
#
#   cp .env.example .env
#
# For production, ALSO see deployment/docker-compose.prod.yml and
# DEPLOYMENT_GUIDE.md — several values below (marked "PRODUCTION") only take
# effect when deploying with:
#   docker compose -f docker-compose.yml -f deployment/docker-compose.prod.yml \
#     --env-file .env up -d --build
#
# NEVER commit the real .env file to version control (.gitignore already
# excludes .env*).
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE (PostgreSQL) — container-to-container via `postgres` hostname
# ------------------------------------------------------------------------------
DB_NAME=cverify_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_PORT=5432

# ------------------------------------------------------------------------------
# 2. REDIS (Caching & distributed state)
# ------------------------------------------------------------------------------
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# 3. HOST PORT MAPPINGS
# All bound to 127.0.0.1 in docker-compose.yml except CLIENT_PORT (public).
# ------------------------------------------------------------------------------
CORE_PORT=5247
AI_PORT=8000
CLIENT_PORT=3000

# ------------------------------------------------------------------------------
# 4. JWT SECURITY (CVerify.Core)
# Key must be at least 32 characters long for HS256.
# ------------------------------------------------------------------------------
JWT_KEY="YOUR_SUPER_SECRET_KEY_HERE_MIN_32_CHARS"
JWT_SECRET="YOUR_SUPER_SECRET_KEY_HERE_MIN_32_CHARS"

# ------------------------------------------------------------------------------
# 5. ASP.NET CORE ENVIRONMENT
# PRODUCTION: set to "Production".
# ------------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development

# ------------------------------------------------------------------------------
# 6. EMAIL INFRASTRUCTURE (SMTP / SendGrid)
# Provider itself is hardcoded to SendGrid in docker-compose.yml's
# `environment:` block for cverify-core (EmailSettings__Provider) — setting it
# here has no effect under Docker, only when running Core outside Docker.
# ------------------------------------------------------------------------------
EMAIL_SENDER_EMAIL=dev@cverify.ai
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=dev_user
SMTP_PASSWORD=dev_password
SENDGRID_API_KEY=SG.your_sendgrid_key_here

# ------------------------------------------------------------------------------
# 7. OAUTH CONFIGURATIONS
# Redirect URIs registered with each provider must point at
# https://<DOMAIN>/api/auth/callback/<provider> in production.
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

GITLAB_CLIENT_ID=your_gitlab_client_id_here
GITLAB_CLIENT_SECRET=your_gitlab_client_secret_here

# ------------------------------------------------------------------------------
# 8. AI MICROSERVICE — HMAC AUTH BETWEEN Core AND AI
# Core reads these as AI_SERVICE_*; deployment/docker-compose.prod.yml maps
# them onto SHARED_SECRET / CLIENT_ID, the names CVerify.AI/app/core/config.py
# actually reads. Without the prod override applied, this mapping does not
# happen and HMAC auth between Core and AI silently fails in production.
# ------------------------------------------------------------------------------
AI_SERVICE_URL=http://cverify-ai:8000
AI_SERVICE_SHARED_SECRET="YOUR_HMAC_SHARED_SECRET_KEY_MIN_32_CHARS"
AI_SERVICE_CLIENT_ID=cverify-core
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ------------------------------------------------------------------------------
# 9. PRIVILEGED SYSTEM IDENTITY (SUPER ADMIN)
# ------------------------------------------------------------------------------
SUPER_ADMIN_EMAIL=admin@system.com
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_FULL_NAME="System Administrator"
SUPER_ADMIN_PASSWORD=SuperAdminPassword123

# ------------------------------------------------------------------------------
# 10. CLOUDFLARE R2 OBJECT STORAGE (evidence files, CV attachments)
# ------------------------------------------------------------------------------
ACCESS_KEY_ID=your_r2_access_key_id_here
SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET=cverify-evidence

# ------------------------------------------------------------------------------
# 11. SECURITY SETTINGS
# ------------------------------------------------------------------------------
DISABLE_RATE_LIMITS=false
# Key must be exactly 32 bytes (256 bits) for AES-256-GCM
TOKEN_ENCRYPTION_KEY="your_32_byte_token_encryption_key_here"

# ------------------------------------------------------------------------------
# 12. DATABASE MANAGEMENT / SEEDING
# PRODUCTION: RESET_DATABASE and ALLOW_DEVELOPMENT_SEEDING must be "false".
# ------------------------------------------------------------------------------
RESET_DATABASE=false
SEED_TEST_ACCOUNTS=true
SEED_BUSINESS_PASSWORD=TestPassword123
SEED_DATA_PATH=resources/seed-business-data.json
PUBLIC_DEMO_DATA_PATH=resources/public-workspace-demo-content.json
ALLOW_DEVELOPMENT_SEEDING=true

# ------------------------------------------------------------------------------
# 13. PRODUCTION-ONLY — read by deployment/docker-compose.prod.yml
# DOMAIN is the frontend's public host. API_DOMAIN is the API's own subdomain
# (deployment/nginx/cverify.conf routes api.<DOMAIN> straight to cverify-core,
# separately from the frontend). API_DOMAIN feeds NEXT_PUBLIC_API_URL
# (build-time, inlined into the frontend bundle — the client image MUST be
# rebuilt after changing this). FRONTEND_URL is the CORS + auth redirect
# origin on the backend; BACKEND_URL is used to build OAuth callback URLs
# (falls back to the incoming request's Host header if left unset).
#
# COOKIE_DOMAIN must be set to a shared parent domain (e.g. ".cverify.io.vn")
# whenever the frontend and API are on different subdomains — otherwise the
# access_token/refresh_token/CSRF-TOKEN cookies set by the API are invisible
# to the frontend (breaks SSR auth checks and all CSRF-protected requests).
# Leave COOKIE_DOMAIN unset for single-host/localhost setups.
#
# Auth__TrustedDomains must include DOMAIN or email-verification and
# password-reset links (built from FRONTEND_URL) are rejected as untrusted.
# ------------------------------------------------------------------------------
DOMAIN=localhost
API_DOMAIN=localhost
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5247
COOKIE_DOMAIN=
Auth__TrustedDomains=localhost;127.0.0.1
