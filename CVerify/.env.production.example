# ==============================================================================
# CVERIFY PRODUCTION ENVIRONMENT TEMPLATE
# ==============================================================================
# Copy this to .env on your VPS/server:
#   cp .env.production.example .env
#
# Replace ALL placeholder values before running docker compose.
# NEVER commit the real .env to git.
# ==============================================================================

# -----------------------------------------------------------------------
# DOMAIN & URLs  (set these first — other values depend on them)
# -----------------------------------------------------------------------
DOMAIN=cverify.yourdomain.com
FRONTEND_URL=https://cverify.yourdomain.com
NEXT_PUBLIC_API_URL=https://cverify.yourdomain.com/api
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# -----------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------
DB_NAME=cverify
DB_USER=cverify_user
DB_PASSWORD=CHANGE_ME_strong_random_password_32chars

# -----------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------
# No password needed if Redis is only accessible inside the Docker network.
# Add --requirepass if exposing port 6379 externally.

# -----------------------------------------------------------------------
# JWT & SESSION SECRETS  (generate with: openssl rand -hex 32)
# -----------------------------------------------------------------------
JWT_KEY=CHANGE_ME_min_32_chars_random_secret
JWT_SECRET=CHANGE_ME_min_32_chars_random_secret

# -----------------------------------------------------------------------
# AI SERVICE SECURITY
# -----------------------------------------------------------------------
AI_SERVICE_SHARED_SECRET=CHANGE_ME_min_32_chars_hmac_secret
ANTHROPIC_API_KEY=sk-ant-your-real-key-here

# -----------------------------------------------------------------------
# EMAIL (SendGrid preferred for production)
# -----------------------------------------------------------------------
SENDGRID_API_KEY=SG.your_sendgrid_key
EMAIL_SENDER_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------
# OAUTH PROVIDERS
# -----------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# -----------------------------------------------------------------------
# CLOUDFLARE R2 OBJECT STORAGE
# -----------------------------------------------------------------------
ACCESS_KEY_ID=your_r2_access_key_id
SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=cverify-evidence

# -----------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------
TOKEN_ENCRYPTION_KEY=CHANGE_ME_exactly_32_bytes_here_!!
DISABLE_RATE_LIMITS=false

# -----------------------------------------------------------------------
# SUPER ADMIN (seed on first boot only)
# -----------------------------------------------------------------------
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_FULL_NAME=System Administrator
SUPER_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# -----------------------------------------------------------------------
# ASP.NET CORE
# -----------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production

# -----------------------------------------------------------------------
# SEEDING (set to false after first boot)
# -----------------------------------------------------------------------
RESET_DATABASE=false
SEED_TEST_ACCOUNTS=false
ALLOW_DEVELOPMENT_SEEDING=false
