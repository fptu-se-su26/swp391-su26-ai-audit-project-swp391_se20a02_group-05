# ==============================================================================
# TRIPGENIE INFRASTRUCTURE CONFIGURATION (.env.example)
# ==============================================================================

# 1. DATABASE (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tripgenie_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# 2. REDIS (Caching & Distributed State)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# 3. JWT SECURITY
# Key must be at least 32 characters long for HS256
JWT_KEY="YOUR_SUPER_SECRET_KEY_HERE_MIN_32_CHARS"

# 4. ASP.NET CORE ENVIRONMENT
ASPNETCORE_ENVIRONMENT=Development
PORT=5247

# 5. EMAIL INFRASTRUCTURE (SMTP / SendGrid)
EMAIL_SENDER_EMAIL=dev@tripgenie.ai
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=dev_user
SMTP_PASSWORD=dev_password
SENDGRID_API_KEY=SG.your_sendgrid_key_here

# 6. GOOGLE OAUTH
GOOGLE_CLIENT_ID=your_google_client_id_here
