{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD}",
    "Redis": "${REDIS_HOST}:${REDIS_PORT},password=${REDIS_PASSWORD}"
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "TripGenie.API",
    "Audience": "TripGenie.Client",
    "DurationInMinutes": 60
  },
  "EmailSettings": {
    "Provider": "Smtp",
    "SenderEmail": "${EMAIL_SENDER_EMAIL}",
    "SenderName": "TripGenie AI",
    "EnableBackgroundQueue": true,
    "RetryCount": 3,
    "RetryDelaySeconds": 2,
    "TimeoutSeconds": 30,
    "Smtp": {
      "Host": "${SMTP_HOST}",
      "Port": "${SMTP_PORT}",
      "Username": "${SMTP_USERNAME}",
      "Password": "${SMTP_PASSWORD}",
      "EnableSsl": true
    },
    "SendGrid": {
      "ApiKey": "${SENDGRID_API_KEY}"
    }
  },
  "AllowedHosts": "*"
}
